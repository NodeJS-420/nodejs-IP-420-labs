<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Наша Команда</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Команда "420 Бригада"</h1>
    <p class="description">Ми розробляємо швидкі та масштабовані веб-додатки з використанням сучасних технологій.</p>

    <h2>Склад команди:</h2>
    <div class="team-grid">
        <% teamMembers.forEach(member => { %>
            <div class="team-member">
                <img src="<%= member.photo %>" alt="<%= member.name %>" class="member-photo">
                <h3><a href="/student/<%= encodeURIComponent(member.name) %>"><%= member.name %></a></h3>
                <p class="role"><%= member.role %></p>
            </div>
        <% }); %>
    </div>

    <p><a href="https://www.justice.gov/epstein" target="_blank">Файли Епштейна</a></p>
</body>
</html>