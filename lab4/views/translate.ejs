<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Переклад</title>
</head>
<body>
    <h1>Форма перекладу</h1>
    
    <form action="/translate" method="GET">
        <label for="word">Слово для перекладу:</label>
        <input type="text" id="word" name="word" required value="<%= typeof original !== 'undefined' ? original : '' %>">
        <br><br>
        
        <label for="lang">ID цільової мови (необов'язково):</label>
        <input type="number" id="lang" name="lang" value="<%= typeof targetLangId !== 'undefined' ? targetLangId : '' %>">
        <br><br>
        
        <button type="submit">Перекласти</button>
    </form>

    <hr>

    <% if (typeof translation !== 'undefined') { %>
        <h2>Результат:</h2>
        <p><strong>Оригінал:</strong> <%= original %></p>
        <p><strong>Переклад:</strong> <%= translation %></p>
    <% } else if (typeof error !== 'undefined') { %>
        <h2 style="color: red;">Помилка:</h2>
        <p><%= error %></p>
    <% } %>

    <br>
    <a href="/">На головну</a>
</body>
</html>